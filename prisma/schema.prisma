// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

// User Model - Admin account
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String
  emailVerified     Boolean   @default(false)
  image             String?
  // Author bio fields
  bio               String?   @db.Text
  authorTitle       String?   // e.g. "محرر أول", "مراسل صحفي"
  twitterUrl        String?
  linkedinUrl       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
  // Phase 1 Backend Audit - Security: Account lockout fields
  failedLoginAttempts Int     @default(0)
  lockedUntil        DateTime?
  articles          Article[]
  sessions          Session[]
  accounts          Account[]
  aiUsage           AiUsage[]
  notifications     Notification[]
  settings          Settings?
  emailVerifications EmailVerification[]
  articleRevisions  ArticleRevision[]

  // Phase 2 Backend Audit - Performance: Add indexes for account lockout queries
  @@index([email])
  @@index([lockedUntil])
  @@index([createdAt(sort: Desc)])
}

// Article Model
model Article {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String    @db.Text
  excerpt         String?   @db.Text
  featuredImageId String?
  featuredImage   Image?    @relation("FeaturedImage", fields: [featuredImageId], references: [id])
  status          String    @default("draft") // draft, published, scheduled, archived
  publishedAt     DateTime?
  scheduledAt     DateTime?
  authorId        String
  author          User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  views           Int       @default(0)
  seoScore        Int       @default(0)
  metaTitle       String?   @db.Text
  metaDescription String?   @db.Text
  focusKeyword    String?
  aiCompletionData Json?    // Stores AI completion results for the AI analysis page
  isFeatured      Boolean   @default(false) // For homepage featured article
  readingTime     Int?      // Estimated reading time in minutes
  wordCount       Int?      // Computed word count for analytics
  articleType     String?   @default("article") // news, report, investigation, opinion, article
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Article Series
  seriesId        String?
  series          ArticleSeries? @relation(fields: [seriesId], references: [id])
  seriesOrder     Int?           // Position within the series

  // Relations
  categories      Category[] @relation("ArticleCategories")
  tags            Tag[]      @relation("ArticleTags")
  images          Image[]    @relation("ArticleImages")
  videos          Video[]
  seoAnalysis     SeoAnalysis?
  previewTokens   PreviewToken[]
  articleViews    ArticleView[]
  revisions       ArticleRevision[]

  // Phase 2 Backend Audit - Performance: Enhanced indexes for common query patterns
  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@index([authorId])
  @@index([isFeatured])
  @@index([seoScore]) // For SEO filtering (good/bad scores)
  @@index([views(sort: Desc)]) // For popular articles
  @@index([status, publishedAt(sort: Desc)]) // For published articles sorted by date
  @@index([status, isFeatured, publishedAt(sort: Desc)]) // For featured articles
  @@index([authorId, status]) // For user's articles by status
  @@index([createdAt(sort: Desc)]) // For recent articles
  @@index([scheduledAt]) // For scheduled posts queue
  @@index([status, scheduledAt]) // For filtering scheduled by status
  @@index([status, createdAt(sort: Desc)]) // For articles by status and date
}

// Article Revision Model - For tracking article content changes
model ArticleRevision {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title       String   @db.Text
  content     String   @db.Text
  excerpt     String?  @db.Text
  metaTitle   String?  @db.Text
  metaDescription String? @db.Text
  changeNote  String?  // Optional note explaining what changed
  isAutoSave  Boolean  @default(false) // Whether this was an automatic save
  createdAt   DateTime @default(now())

  @@index([articleId])
  @@index([articleId, createdAt(sort: Desc)]) // For getting article history
  @@index([authorId])
}

// Category Model - Hierarchical structure
model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?    @db.Text
  color       String     @default("#3b82f6") // Hex color code for category identification
  order       Int        @default(0) // For drag-and-drop reordering
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  articles    Article[]  @relation("ArticleCategories")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([slug])
  @@index([parentId])
  @@index([name]) // For category search
  @@index([order]) // For ordering categories
}

// Tag Model
model Tag {
  id          String    @id @default(cuid())
  name        String    @unique
  nameEn      String?   @unique
  slug        String    @unique
  description String?
  articles    Article[] @relation("ArticleTags")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  // Phase 2 Backend Audit - Performance: Index for tag queries
  @@index([slug])
  @@index([name]) // For tag search
  @@index([nameEn]) // For English name search
}

// Image Model
model Image {
  id                  String    @id @default(cuid())
  url                 String
  thumbnailUrl        String?
  mediumUrl           String?
  largeUrl            String?
  cloudinaryPublicId  String?   // Cloudinary public ID for management/deletion
  altText             String?   @db.Text
  caption             String?   @db.Text
  filename            String
  fileSize            Int
  width               Int
  height              Int
  mimeType            String
  uploadedAt          DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  articles                Article[] @relation("ArticleImages")
  featuredInArticles      Article[] @relation("FeaturedImage")

  @@index([filename])
  @@index([uploadedAt])
  @@index([cloudinaryPublicId])
}

// Video Model - YouTube integration
model Video {
  id          String   @id @default(cuid())
  youtubeUrl  String
  youtubeId   String
  title       String?  @db.Text
  thumbnail   String
  privacyMode Boolean  @default(false)
  autoplay    Boolean  @default(false)
  startTime   Int      @default(0)
  position    Int      // Order in article
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([youtubeId])
  @@index([articleId])
}

// SEO Analysis Model
model SeoAnalysis {
  id          String   @id @default(cuid())
  articleId   String   @unique
  score       Int
  suggestions Json     // Array of suggestion objects
  criteria    Json     // Checklist status
  analyzedAt  DateTime @default(now())
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

// Account Model (for Better Auth - required even without social providers)
model Account {
  id                String   @id @default(cuid())
  userId            String
  accountId         String
  providerId        String
  accessToken       String?
  refreshToken       String?
  idToken           String?
  expiresAt         DateTime?
  password          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

// Session Model (for Better Auth)
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  userId    String
  ipAddress String?  // IP address of the user
  userAgent String?  // User agent string
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Phase 2 Backend Audit - Performance: Improved session query indexes
  @@index([userId])
  @@index([expiresAt])
  @@index([token])
  @@index([userId, expiresAt])
}

// Login Attempt Model - For tracking failed login attempts (throttling)
model LoginAttempt {
  id         String   @id @default(cuid())
  identifier String   // IP address or email
  success    Boolean  @default(false)
  attemptedAt DateTime @default(now())
  ip         String?  // Optional IP for additional tracking

  @@index([identifier, attemptedAt])
}

// AI Usage Model - For tracking Gemini API usage per user
model AiUsage {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature      String   // e.g., "seo-suggestions", "meta-title", "grammar-check"
  model        String   // e.g., "gemini-3-flash"
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  inputCost    Float    @default(0)  // Cost in USD (micro-dollars for precision)
  outputCost   Float    @default(0)  // Cost in USD
  totalCost    Float    @default(0)  // Total cost in USD
  cached       Boolean  @default(false)  // Whether response was served from cache
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([feature])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([userId, feature, createdAt(sort: Desc)]) // For user AI usage analytics
  @@index([feature, createdAt(sort: Desc)]) // For feature usage stats
}

// Notification Model - For in-app notifications
model Notification {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String   // e.g., "article_published", "article_scheduled", "system"
  title        String   // Notification title (Arabic)
  message      String   @db.Text // Notification message (Arabic)
  actionUrl    String?  // Optional URL to navigate to when clicked
  actionLabel  String?  // Optional label for action button (Arabic)
  read         Boolean  @default(false)
  readAt       DateTime?
  metadata     Json?    // Optional additional data (articleId, etc.)
  createdAt    DateTime @default(now())

  // Phase 2 Backend Audit - Performance: Improved notification query indexes
  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)]) // For user notifications sorted by date
  @@index([read, createdAt(sort: Desc)]) // For unread notifications
  @@index([type]) // For filtering by notification type
  @@index([userId, read, createdAt(sort: Desc)]) // Composite for user's unread notifications
}

// Preview Token Model - For secure article preview access
model PreviewToken {
  id           String   @id @default(cuid())
  articleId    String
  article      Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
  @@index([articleId])
  @@index([expiresAt])
}

// Article View Model - For tracking article views (prevents duplicate counts)
model ArticleView {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  sessionId String?  // Optional session identifier for deduplication
  ipAddress String?  // Optional IP address tracking
  userAgent String?  // Optional user agent tracking
  viewedAt  DateTime @default(now())

  // Phase 2 Backend Audit - Performance: Improved view tracking indexes
  @@unique([articleId, sessionId])
  @@index([articleId])
  @@index([sessionId])
  @@index([ipAddress])
  @@index([viewedAt])
  @@index([articleId, viewedAt(sort: Desc)]) // For article views analytics
  @@index([sessionId, ipAddress]) // For session + IP deduplication
  @@index([articleId, sessionId, ipAddress]) // Composite for fast lookup
}

// Site Settings Model - For storing site-wide configuration
model Settings {
  id        String   @id @default(cuid())
  userId    String   @unique // One settings record per user/admin
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // General Settings
  siteName        String   @default("موقعي")
  siteTagline     String?  @db.Text
  adminEmail      String?

  // Date/Time Settings
  timezone        String   @default("Asia/Riyadh")
  dateFormat      String   @default("DD/MM/YYYY")
  timeFormat      String   @default("24") // "12" or "24"

  // SEO Settings
  defaultMetaTitle       String?  @db.Text
  defaultMetaDescription String?  @db.Text
  siteKeywords           String?  @db.Text
  googleAnalyticsId      String?
  googleSearchConsole    String?
  facebookHandle         String?
  twitterHandle          String?
  instagramHandle        String?
  youtubeHandle          String?

  // Media Settings
  maxUploadSize          Int      @default(10) // in MB
  imageQuality           Int      @default(85) // 1-100
  storageProvider        String   @default("cloudinary") // "cloudinary" or "vercel-blob"

  // Publishing Settings
  defaultArticleStatus   String   @default("draft") // "draft" or "published"
  autoPublishEnabled     Boolean  @default(false)
  defaultCategories      String?  // JSON array of category IDs
  notifyOnPublish        Boolean  @default(true)

  // AI Settings
  aiModelPreference      String   @default("gemini-3-flash")
  aiResponseLimit        Int      @default(4096) // max tokens
  aiFeaturesEnabled      Boolean  @default(true)

  // Breaking News Settings
  breakingNewsEnabled    Boolean  @default(false)
  breakingNewsText       String?  @db.Text
  breakingNewsUrl        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Article Series Model - Group related articles into a series
model ArticleSeries {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?   @db.Text
  coverImage  String?   // URL of cover image
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  articles    Article[]

  @@index([slug])
  @@index([createdAt(sort: Desc)])
}

// Newsletter Subscriber Model
model Subscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  confirmed   Boolean  @default(false)
  token       String?  @unique  // Confirmation token
  subscribedAt DateTime @default(now())
  confirmedAt  DateTime?
  unsubscribedAt DateTime?
  active      Boolean  @default(true)

  @@index([email])
  @@index([active])
  @@index([subscribedAt(sort: Desc)])
}

// Email Verification Model - For storing email verification tokens
model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  verifiedAt DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
  @@index([expiresAt])
}
